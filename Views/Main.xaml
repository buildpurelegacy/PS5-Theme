                                                                Binding="{PluginSettings Plugin=PS5Core, Path=SelfState}"
                                                                Value="away">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
