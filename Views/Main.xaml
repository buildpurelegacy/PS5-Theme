                                    </StackPanel>

                                </ButtonEx>
                                <Border BorderThickness="0.5" BorderBrush="White" Margin="104,4,0,0"
                                        VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="525" Opacity="0.1" />

                                <ButtonEx Width="640" Height="90" Margin="0,6,0,0" Background="Transparent"
                                        HorizontalContentAlignment="Left">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Grid Width="48" HorizontalAlignment="Left">
                                            <Image Source="{ThemeFile 'Assets/Profile/Trophy.png'}" Width="32"
                                                    VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        </Grid>
                                        <Grid Width="592" Height="90" VerticalAlignment="Center"
