                                                                                    </DoubleAnimation>
                                                                                    <DoubleAnimation
                                                                                            Storyboard.TargetName="UserScale"
                                                                                            Storyboard.TargetProperty="ScaleY"
                                                                                            To="1" Duration="0:0:0.20">
                                                                                        <DoubleAnimation.EasingFunction>
                                                                                            <CubicEase
                                                                                                    EasingMode="EaseIn" />
                                                                                        </DoubleAnimation.EasingFunction>
                                                                                    </DoubleAnimation>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </Trigger.EnterActions>

                                                                        <Trigger.ExitActions>
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <DoubleAnimation
                                                                                            Storyboard.TargetName="UserScale"
                                                                                            Storyboard.TargetProperty="ScaleX"
                                                                                            To="0.7571428571428571"
                                                                                            Duration="0:0:0.20">
                                                                                        <DoubleAnimation.EasingFunction>
                                                                                            <CubicEase
                                                                                                    EasingMode="EaseOut" />
