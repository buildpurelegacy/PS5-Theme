            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">

                    <Grid Width="300" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,300,90,0">
                        <Border Grid.RowSpan="2" CornerRadius="6" Background="{DynamicResource PS5BasicGradient}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="50" Color="Black" Opacity="0.5" />
                            </Border.Effect>
                        </Border>
                        <StackPanel Orientation="Vertical" Margin="0,0,0,0" VerticalAlignment="Top">

                            <ButtonEx pbeh:FocusBahaviors.FocusBinding="True"
                                    pbeh:FocusBahaviors.OnVisibilityFocus="True" Width="290" Height="65"
                                    Margin="0,6,0,0" Background="Transparent" HorizontalContentAlignment="Left"
                                    Command="{PluginSettings Plugin=PS5Core, Path=SetStatusOnlineCommand}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Grid Width="35" HorizontalAlignment="Left">
                                        <TextBlock Margin="-5,0,5,0" HorizontalAlignment="Center"
                                                VerticalAlignment="Center" Text="&#xeed6;"
                                                FontFamily="{StaticResource FontIcoFont}" Foreground="White"
                                                FontSize="34">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger
                                                                Binding="{PluginSettings Plugin=PS5Core, Path=SelfState}"
                                                                Value="online">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                            HorizontalAlignment="Right">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                Margin="0,0,10,0">
                                            <Ellipse Width="20" Height="20">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#14fe83" />
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Margin="20,0,0,0" VerticalAlignment="Center" FontSize="28"
                                                    Foreground="White" FontFamily="Segoe UI Light">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Online" />
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

