                                                <Style.Triggers>
                                                    <DataTrigger
                                                            Binding="{Binding ElementName=PART_PS5CoreUsersList, Path=SelectedIndex}"
                                                            Value="0">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                            To="0" Duration="0:0:0.25" />
