                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="0"
                                                Duration="0:0:0.20" FillBehavior="HoldEnd" />
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" BeginTime="0:0:0.20"
                                                From="0" To="1" Duration="0:0:0.35" FillBehavior="HoldEnd" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Grid.Triggers>

                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PS5AddUserStyle" TargetType="ContentControl">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">

                    <Grid Background="Black">
                        <Grid x:Name="LoginPageBackground">
                            <MediaElement Source="{ThemeFile 'Assets/Backgrounds/Video/PS5particles.mp4'}"
                                    UnloadedBehavior="Close">
                                <MediaElement.Style>
                                    <Style TargetType="MediaElement">
                                        <Setter Property="MediaElementBehaviors.Repeat" Value="True" />
                                        <Setter Property="LoadedBehavior" Value="Close" />
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger
                                                    Binding="{Binding ElementName=AddUserContainer, Path=Visibility}"
                                                    Value="Visible">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Setter Property="LoadedBehavior" Value="Play" />
                                            </DataTrigger>
                                            <Trigger Property="Visibility" Value="Collapsed">
                                                <Setter Property="Source" Value="" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </MediaElement.Style>
                            </MediaElement>
                        </Grid>
                        <Grid x:Name="AddUserContainer">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="200" />
                            </Grid.RowDefinitions>
                            <Grid x:Name="AddUserPage1" Grid.Row="0">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Setter Property="Opacity" Value="0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{PluginSettings Plugin=PS5Core, Path=AddUserPage}"
                                                    Value="1">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                    From="0" To="1" Duration="0:0:0.3" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                    From="1" To="0" Duration="0:0:0.3" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="200" />
                                        <RowDefinition Height="80" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <TextBlock Text="Add User" Margin="0,0,0,50" HorizontalAlignment="Center"
                                                VerticalAlignment="Bottom" FontFamily="Segoe UI Semilight" FontSize="56"
                                                Foreground="White" />
                                    </Grid>

                                    <Grid Grid.Row="1" />

                                    <Grid Grid.Row="2">

                                        <ButtonEx HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0"
                                                Command="{PluginSettings Plugin=PS5Core, Path=OpenAddUserAvatarPickerCommand}">
                                            <ButtonEx.Template>
                                                <ControlTemplate TargetType="ButtonEx">
                                                    <Grid Width="260" Height="260">
                                                        <Border x:Name="Mask" Background="Black" CornerRadius="250"
                                                                Width="250" Height="250" />
                                                        <Grid>
                                                            <Grid.OpacityMask>
                                                                <VisualBrush Visual="{Binding ElementName=Mask}" />
                                                            </Grid.OpacityMask>
                                                            <Image
                                                                    Source="{PluginSettings Plugin=PS5Core, Path=NewUserAvatar}"
                                                                    Width="250" Height="250" Stretch="UniformToFill"
                                                                    ClipToBounds="True" />
                                                        </Grid>

                                                        <Border x:Name="MainBorder" Margin="-6" BorderThickness="3"
                                                                CornerRadius="270" Style="{DynamicResource PS5Border}"
                                                                Visibility="Hidden" />
                                                        <Border x:Name="FlashBorder" Margin="0" Width="250" Height="250"
                                                                CornerRadius="250" Style="{DynamicResource PS5Cover}"
                                                                Visibility="Hidden" />
                                                    </Grid>

                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsFocused" Value="True">
                                                            <Setter TargetName="MainBorder" Property="Visibility"
                                                                    Value="Visible" />
                                                            <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                                                            <Setter TargetName="FlashBorder" Property="Visibility"
                                                                    Value="Visible" />
                                                            <Setter TargetName="FlashBorder" Property="Tag" Value="True" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </ButtonEx.Template>
                                        </ButtonEx>

                                        <StackPanel Margin="0,0,0,150" VerticalAlignment="Bottom"
                                                HorizontalAlignment="Center">

                                            <TextBlock Text="Name" Foreground="White" Margin="0,0,0,10" FontSize="22"
                                                    FontFamily="Segoe UI" Opacity="0.6" />

                                            <ButtonEx
                                                    Command="{PluginSettings Plugin=PS5Core, Path=EditNewUserNameCommand}">
                                                <ButtonEx.Template>
                                                    <ControlTemplate TargetType="ButtonEx">
                                                        <Grid Width="780" Height="80">
                                                            <Grid Background="Transparent" Margin="0,0,0,30" />
                                                            <StackPanel Orientation="Vertical">
                                                                <TextBlock Margin="20,0,0,10"
                                                                        Text="{PluginSettings Plugin=PS5Core, Path=NewUserName}"
                                                                        FontSize="28" FontFamily="Segoe UI"
                                                                        Foreground="White" />
                                                                <Border x:Name="Underline" Height="2"
                                                                        Background="#40FFFFFF" />
                                                            </StackPanel>
                                                            <TextBlock x:Name="Checkmark" HorizontalAlignment="Right"
                                                                    Margin="0,5,5,0" Text="&#xeed7;"
                                                                    FontFamily="{StaticResource FontIcoFont}"
                                                                    Foreground="White" FontSize="28" />

                                                            <Border x:Name="MainBorder" Margin="-3,-10,-3,30"
                                                                    BorderThickness="3" CornerRadius="3"
                                                                    Style="{DynamicResource PS5Border}"
                                                                    Visibility="Hidden" />
                                                            <Border x:Name="FlashBorder" Margin="0,-5,0,35"
                                                                    Style="{DynamicResource PS5Cover}"
                                                                    Visibility="Hidden" />
                                                        </Grid>

                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsFocused" Value="True">
                                                                <Setter TargetName="MainBorder" Property="Visibility"
                                                                        Value="Visible" />
                                                                <Setter TargetName="MainBorder" Property="Tag"
                                                                        Value="True" />
                                                                <Setter TargetName="FlashBorder" Property="Visibility"
                                                                        Value="Visible" />
                                                                <Setter TargetName="FlashBorder" Property="Tag"
                                                                        Value="True" />
                                                            </Trigger>
                                                            <DataTrigger
                                                                    Binding="{PluginSettings Plugin=PS5Core, Path=NewUserName}"
                                                                    Value="Playnite User">
                                                                <Setter TargetName="Checkmark" Property="Visibility"
                                                                        Value="Collapsed" />
                                                            </DataTrigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ButtonEx.Template>
                                            </ButtonEx>

                                        </StackPanel>

                                    </Grid>
                                </Grid>
                            </Grid>
                            <Grid x:Name="AddUserPage2" Grid.Row="0">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Setter Property="Opacity" Value="0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{PluginSettings Plugin=PS5Core, Path=AddUserPage}"
                                                    Value="2">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                    From="0" To="0" Duration="0:0:0.5" />
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                    BeginTime="0:0:0.5" From="0" To="1"
                                                                    Duration="0:0:0.3" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                    From="1" To="0" Duration="0:0:0.3" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="200" />
                                        <RowDefinition Height="80" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid x:Name="BackroundTitle" Grid.Row="0">
                                        <TextBlock Text="Choose Welcome Hub Background" Margin="0,-5,0,50"
                                                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                                FontFamily="Segoe UI Semilight" FontSize="56" Foreground="White" />
                                    </Grid>
                                    <Grid x:Name="BackgroundDescription" Grid.Row="1">
                                        <TextBlock
                                                Text="Personalize your Welcome Hub. Choose a background that reflects your style or matches your setup."
                                                Margin="0,0,0,50" HorizontalAlignment="Center"
                                                VerticalAlignment="Center" FontFamily="Segoe UI Light" Opacity="0.5"
                                                FontSize="24" Foreground="White" />
                                    </Grid>

                                    <ButtonEx Grid.Row="2" Width="889" Height="500" VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Command="{PluginSettings Plugin=PS5Core, Path=OpenNewUserBackgroundPickerCommand}">
                                        <ButtonEx.Style>
                                            <Style TargetType="ButtonEx">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ButtonEx">
                                                            <Grid>
                                                                <Image
                                                                        Source="{PluginSettings Plugin=PS5Core, Path=NewUserWelcomeBackgroundPath}"
                                                                        Stretch="UniformToFill" />
                                                                <Image RenderOptions.BitmapScalingMode="Fant"
                                                                        Source="{ThemeFile 'Assets/Backgrounds/Dashboard/PS5Overlay.png'}"
                                                                        Stretch="UniformToFill" />

                                                                <Image Opacity="0.7"
                                                                        Source="{ThemeFile 'Assets/Backgrounds/Dashboard/OverlayPicker.png'}"
                                                                        Stretch="UniformToFill" />

                                                                <Border x:Name="MainBorder" Margin="-6"
                                                                        BorderThickness="3" CornerRadius="3" Opacity="1"
                                                                        Style="{DynamicResource PS5Border}" Tag="False"
                                                                        Visibility="Hidden">
                                                                    <Border.CacheMode>
                                                                        <BitmapCache EnableClearType="False"
                                                                                RenderAtScale="1"
                                                                                SnapsToDevicePixels="False" />
                                                                    </Border.CacheMode>
                                                                </Border>
                                                                <Border x:Name="FlashBorder" Margin="0" Opacity="1"
                                                                        Style="{DynamicResource PS5Cover}" Tag="False"
                                                                        Visibility="Hidden">
                                                                    <Border.CacheMode>
                                                                        <BitmapCache EnableClearType="False"
                                                                                RenderAtScale="1"
                                                                                SnapsToDevicePixels="False" />
                                                                    </Border.CacheMode>
                                                                </Border>

                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsFocused" Value="True">
                                                                    <Setter TargetName="MainBorder"
                                                                            Property="Visibility" Value="Visible" />
                                                                    <Setter TargetName="MainBorder" Property="Tag"
                                                                            Value="True" />
                                                                    <Setter TargetName="FlashBorder"
                                                                            Property="Visibility" Value="Visible" />
                                                                    <Setter TargetName="FlashBorder" Property="Tag"
                                                                            Value="True" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ButtonEx.Style>
                                    </ButtonEx>
                                </Grid>
                            </Grid>
                            <Grid x:Name="AddUserButtons" Grid.Row="1" VerticalAlignment="Bottom">

                                <Grid x:Name="AddUserProgress" Margin="40,0,0,-4" VerticalAlignment="Bottom"
                                        HorizontalAlignment="Left">

                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Style.Triggers>

                                                <DataTrigger Binding="{PluginSettings Plugin=PS5Core, Path=AddUserPage}"
                                                        Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>

                                                <DataTrigger Binding="{PluginSettings Plugin=PS5Core, Path=AddUserPage}"
                                                        Value="3">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                        From="1" To="0" Duration="0:0:0.5" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                </DataTrigger>

                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid Margin="0,0,0,40">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Height="4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#595959" />
                                                    <Style.Triggers>
                                                        <DataTrigger
                                                                Binding="{PluginSettings Plugin=PS5Core, Path=AddUserPage}"
                                                                Value="1">
                                                            <Setter Property="Background" Value="#969696" />
                                                        </DataTrigger>
                                                        <DataTrigger
                                                                Binding="{PluginSettings Plugin=PS5Core, Path=AddUserPage}"
                                                                Value="2">
                                                            <Setter Property="Background" Value="#969696" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <Border Grid.Column="2" Height="4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#595959" />
                                                    <Style.Triggers>
                                                        <DataTrigger
                                                                Binding="{PluginSettings Plugin=PS5Core, Path=AddUserPage}"
                                                                Value="2">
                                                            <Setter Property="Background" Value="#969696" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                    </Grid>

                                </Grid>
                                <StackPanel Margin="0,0,0,120" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                        Orientation="Horizontal">

                                    <Grid Margin="0,0,35,0">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger
                                                            Binding="{PluginSettings Plugin=PS5Core, Path=AddUserPage}"
                                                            Value="2">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>

                                        <ButtonEx Content="Back" Style="{DynamicResource PS5ButtonStyle}"
                                                Command="{PluginSettings Plugin=PS5Core, Path=AddUserPrevCommand}" />
                                    </Grid>

                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger
                                                            Binding="{PluginSettings Plugin=PS5Core, Path=AddUserPage}"
                                                            Value="2">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>

                                        <ButtonEx Content="Next" pbeh:FocusBahaviors.FocusBinding="True"
                                                pbeh:FocusBahaviors.OnVisibilityFocus="True"
                                                Style="{DynamicResource PS5ButtonStyle}"
                                                Command="{PluginSettings Plugin=PS5Core, Path=AddUserNextCommand}" />
                                    </Grid>

                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Setter Property="Opacity" Value="0" />
                                                <Style.Triggers>

                                                    <DataTrigger
                                                            Binding="{PluginSettings Plugin=PS5Core, Path=AddUserPage}"
                                                            Value="2">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                            From="0" To="1" Duration="0:0:0.3" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>

                                        <ButtonEx Content="Add User" pbeh:FocusBahaviors.FocusBinding="True"
                                                pbeh:FocusBahaviors.OnVisibilityFocus="True"
                                                Style="{DynamicResource PS5ButtonStyle}"
                                                Command="{PluginSettings Plugin=PS5Core, Path=AddUserFinishCommand}" />
                                    </Grid>

                                </StackPanel>

                            </Grid>

                        </Grid>

                    </Grid>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="PS5UserMenuStyle" TargetType="ContentControl">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid>
                        <Grid x:Name="Content" Margin="700,0,0,0" Background="{DynamicResource PS5BasicGradient}"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                            <StackPanel x:Name="Stack" Width="300" Orientation="Vertical">
                                <ButtonEx pbeh:FocusBahaviors.FocusBinding="True"
                                        pbeh:FocusBahaviors.OnVisibilityFocus="True" Width="290" Height="65"
                                        Margin="0,6,0,0" Background="Transparent" HorizontalContentAlignment="Left"
                                        Command="{PluginSettings Plugin=PS5Core, Path=SetStatusOnlineCommand}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Grid Width="35" HorizontalAlignment="Left">
                                            <TextBlock Margin="-5,0,5,0" HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" Text="&#xeed6;"
                                                    FontFamily="{StaticResource FontIcoFont}" Foreground="White"
                                                    FontSize="34">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger
                                                                    Binding="{PluginSettings Plugin=PS5Core, Path=SelfState}"
                                                                    Value="online">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                    Margin="0,0,10,0">
                                                <Ellipse Width="20" Height="20">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#14fe83" />
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Margin="20,0,0,0" VerticalAlignment="Center" FontSize="28"
                                                        Foreground="White" FontFamily="Segoe UI Light">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Online" />
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                </ButtonEx>

                                <ButtonEx Width="290" Height="65"
                                        Command="{PluginSettings Plugin=PS5Core, Path=SetStatusAwayCommand}"
                                        Margin="0,6,0,0" Background="Transparent" HorizontalContentAlignment="Left">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Grid Width="35" HorizontalAlignment="Left">
                                            <TextBlock Margin="-5,0,5,0" HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" Text="&#xeed6;"
                                                    FontFamily="{StaticResource FontIcoFont}" Foreground="White"
                                                    FontSize="34">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger
                                                                    Binding="{PluginSettings Plugin=PS5Core, Path=SelfState}"
                                                                    Value="away">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                    Margin="0,0,10,0">
                                                <Ellipse Width="20" Height="20">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#fca612" />
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Margin="20,0,0,0" VerticalAlignment="Center" FontSize="28"
                                                        Foreground="White" FontFamily="Segoe UI Light">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Busy" />
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                </ButtonEx>

                                <ButtonEx Width="290" Height="65" Margin="0,6,0,0" Background="Transparent"
                                        Command="{PluginSettings Plugin=PS5Core, Path=SetStatusInvisibleCommand}"
                                        HorizontalContentAlignment="Left">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Grid Width="35" HorizontalAlignment="Left">
                                            <TextBlock Margin="-5,0,5,0" HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" Text="&#xeed6;"
                                                    FontFamily="{StaticResource FontIcoFont}" Foreground="White"
                                                    FontSize="34">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger
                                                                    Binding="{PluginSettings Plugin=PS5Core, Path=SelfState}"
                                                                    Value="offline">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                    Margin="0,0,10,0">
                                                <Ellipse Width="20" Height="20">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="Transparent" />
                                                            <Setter Property="Stroke" Value="White" />
                                                            <Setter Property="StrokeDashArray" Value="2 2" />
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Margin="20,0,0,0" VerticalAlignment="Center" FontSize="28"
                                                        Foreground="White" FontFamily="Segoe UI Light">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Appear Offline" />
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                </ButtonEx>

                                <Border x:Name="Underline" Margin="10,1,10,1" Height="2" Background="#40FFFFFF"
                                        VerticalAlignment="Bottom" />

                                <ButtonEx Content="Remove User" Margin="9,9,9,9" pbeh:FocusBahaviors.FocusBinding="True"
                                        pbeh:FocusBahaviors.OnVisibilityFocus="True"
                                        Command="{PluginSettings Plugin=PS5Core, Path=RemoveUserCommand}"
                                        CommandParameter="{PluginSettings Plugin=PS5Core, Path=SelectedUserItem.Id}" />

                            </StackPanel>
                        </Grid>

                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PS5PowerMenuStyle" TargetType="ContentControl">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid>
                        <Grid x:Name="Content" Margin="0,0,0,150" Background="{DynamicResource PS5BasicGradient}"
                                VerticalAlignment="Bottom" HorizontalAlignment="Center">
                            <TextBlock Margin="20,15,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
                                    FontFamily="Segoe UI Light" FontSize="26" Foreground="White" Opacity="0.7"
                                    Text="Power" />

                            <StackPanel x:Name="Stack" Width="650" Margin="0,70,0,0" Orientation="Vertical">

                                <ButtonEx Content="Exit Playnite" Margin="9" pbeh:FocusBahaviors.FocusBinding="True"
                                        pbeh:FocusBahaviors.OnVisibilityFocus="True"
                                        Style="{DynamicResource PS5TurnExit}"
                                        Command="{PluginSettings Plugin=PS5Core, Path=PowerExitCommand}" />
                                <ButtonEx Content="Turn Off PS5" Margin="9" Style="{DynamicResource PS5TurnTurnoff}"
                                        Command="{PluginSettings Plugin=PS5Core, Path=PowerShutdownCommand}" />

                                <ButtonEx Content="Restart PS5" Margin="9" Style="{DynamicResource PS5TurnRestart}"
                                        Command="{PluginSettings Plugin=PS5Core, Path=PowerRestartCommand}" />

                            </StackPanel>
                        </Grid>
                        <MediaElement Source="{ThemeFile 'Assets/Power/PS5Power.mp4'}" UnloadedBehavior="Close">
