                                            <DataTrigger Binding="{PluginSettings Plugin=PS5Core, Path=WizardCompleted}"
                                                    Value="False">
                                                <Setter Property="LoadedBehavior" Value="Play" />
                                            </DataTrigger>
                                            <DataTrigger
                                                    Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}, Path=IsActive}"
                                                    Value="False">
                                                <Setter Property="MediaElement.Source" Value=" " />
                                            </DataTrigger>
                                            <DataTrigger Binding="{PluginSettings Plugin=PS5Core, Path=WizardCompleted}"
                                                    Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Setter Property="Source" Value="" />
                                                <Setter Property="LoadedBehavior" Value="Close" />
                                                <Setter Property="MediaElementBehaviors.Repeat" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </MediaElement.Style>
                            </MediaElement>
                        </Grid>

                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PS5AvatarPickerStyle" TargetType="ContentControl">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="200" />
                            <RowDefinition Height="80" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <MediaElement Grid.Row="0" Grid.RowSpan="3"
                                Source="{ThemeFile 'Assets/Backgrounds/Video/PS5particles.mp4'}"
                                UnloadedBehavior="Close">
                            <MediaElement.Style>
                                <Style TargetType="MediaElement">
                                    <Setter Property="MediaElementBehaviors.Repeat" Value="True" />
                                    <Setter Property="LoadedBehavior" Value="Play" />
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger
                                                Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}, Path=IsActive}"
                                                Value="False">
                                            <Setter Property="MediaElement.Source" Value=" " />
                                            <Setter Property="MediaElementBehaviors.Repeat" Value="False" />
                                            <Setter Property="LoadedBehavior" Value="Stop" />
                                        </DataTrigger>

                                    </Style.Triggers>
                                </Style>
                            </MediaElement.Style>
                        </MediaElement>
                        <Grid x:Name="AvatarTitle" Grid.Row="0">
                            <TextBlock Text="Avatar" Margin="0,-5,0,50" HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom" FontFamily="Segoe UI Semilight" FontSize="56"
                                    Foreground="White" />
                        </Grid>
                        <Grid x:Name="AvatarDescription" Grid.Row="1">
                            <TextBlock Text="Choose one of the default Avatar, or choose custom one." Margin="0,0,0,50"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI Light"
                                    Opacity="0.5" FontSize="24" Foreground="White" />
                        </Grid>

                        <ItemsControl Grid.Row="2" Focusable="False" AlternationCount="500"
                                ItemsSource="{Binding Avatars}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Margin="100,0,100,20" Rows="4" Columns="8" Focusable="False" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>

                                    <ButtonEx Command="{Binding DataContext.SelectAvatarCommand,
                      RelativeSource={RelativeSource AncestorType=ContentControl}}" CommandParameter="{Binding}"
                                            Background="Transparent" BorderThickness="0" Width="175" Height="175"
                                            Margin="5">

                                        <ButtonEx.Template>
                                            <ControlTemplate TargetType="ButtonEx">
                                                <Grid Width="175" Height="175">

                                                    <Border x:Name="Mask" Background="Black" CornerRadius="175"
                                                            Width="175" Height="175" HorizontalAlignment="Center"
                                                            VerticalAlignment="Center" />

                                                    <Grid>
                                                        <Grid.OpacityMask>
                                                            <VisualBrush Visual="{Binding ElementName=Mask}" />
                                                        </Grid.OpacityMask>

                                                        <Image x:Name="AvatarImage" Source="{Binding}"
                                                                Stretch="UniformToFill" ClipToBounds="True"
                                                                Visibility="Visible" />

                                                        <Grid x:Name="PlusIcon" Visibility="Collapsed">
                                                            <Ellipse Fill="White" Opacity="0.2" Width="175" Height="175" />
                                                            <TextBlock Text="+" FontSize="72" FontWeight="Bold"
                                                                    Foreground="White" HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center" />
                                                        </Grid>
                                                        <Border x:Name="FlashBorder" Margin="0" CornerRadius="0"
                                                                Opacity="1" Style="{DynamicResource PS5Cover}"
                                                                Tag="False" Visibility="Hidden">
                                                            <Border.CacheMode>
                                                                <BitmapCache EnableClearType="False" RenderAtScale="1"
                                                                        SnapsToDevicePixels="False" />
                                                            </Border.CacheMode>
                                                        </Border>
                                                    </Grid>
                                                    <Border x:Name="MainBorder" Margin="-6" BorderThickness="3"
                                                            CornerRadius="175" Opacity="1"
                                                            Style="{DynamicResource PS5Border}" Tag="False"
                                                            Visibility="Hidden">
                                                        <Border.CacheMode>
                                                            <BitmapCache EnableClearType="False" RenderAtScale="1"
                                                                    SnapsToDevicePixels="False" />
                                                        </Border.CacheMode>
                                                    </Border>

                                                </Grid>

                                                <ControlTemplate.Triggers>
                                                    <DataTrigger
                                                            Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}"
                                                            Value="0">
                                                        <Setter Property="pbeh:FocusBahaviors.FocusBinding" Value="True" />
                                                        <Setter Property="pbeh:FocusBahaviors.OnVisibilityFocus"
                                                                Value="True" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding}" Value="CUSTOM">
                                                        <Setter TargetName="AvatarImage" Property="Visibility"
                                                                Value="Collapsed" />
                                                        <Setter TargetName="PlusIcon" Property="Visibility"
                                                                Value="Visible" />
                                                    </DataTrigger>

                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter TargetName="MainBorder" Property="Visibility"
                                                                Value="Visible" />
                                                        <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                                                        <Setter TargetName="FlashBorder" Property="Visibility"
                                                                Value="Visible" />
                                                        <Setter TargetName="FlashBorder" Property="Tag" Value="True" />
                                                    </Trigger>

                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ButtonEx.Template>

                                    </ButtonEx>

                                </DataTemplate>
                            </ItemsControl.ItemTemplate>

                        </ItemsControl>
                        <Grid.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="0"
                                                Duration="0:0:0.20" FillBehavior="HoldEnd" />
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" BeginTime="0:0:0.20"
                                                From="0" To="1" Duration="0:0:0.35" FillBehavior="HoldEnd" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Grid.Triggers>

                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

