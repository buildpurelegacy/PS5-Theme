                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PS5SplashscreenSelector" TargetType="ContentControl">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="200" />
                            <RowDefinition Height="80" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="120" />
                        </Grid.RowDefinitions>

                        <MediaElement Grid.Row="0" Grid.RowSpan="4"
                                Source="{ThemeFile 'Assets/Backgrounds/Video/PS5particles.mp4'}"
                                UnloadedBehavior="Close">
                            <MediaElement.Style>
                                <Style TargetType="MediaElement">
                                    <Setter Property="MediaElementBehaviors.Repeat" Value="True" />
                                    <Setter Property="LoadedBehavior" Value="Play" />
                                </Style>
                            </MediaElement.Style>
                        </MediaElement>

                        <Grid Grid.Row="0">
                            <TextBlock Text="Game Splashscreen" Margin="0,-5,0,50" HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom" FontFamily="Segoe UI Semilight" FontSize="56"
                                    Foreground="White" />
                        </Grid>

                        <Grid Grid.Row="1">
                            <TextBlock Text="Choose a custom splashscreen image for this game."
                                    HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI Light"
                                    Opacity="0.5" FontSize="24" Foreground="White" />
                        </Grid>

                        <ButtonEx Grid.Row="2" Width="889" Height="500" VerticalAlignment="Center"
                                HorizontalAlignment="Center" pbeh:FocusBahaviors.OnVisibilityFocus="True"
                                pbeh:FocusBahaviors.FocusBinding="True"
                                Command="{PluginSettings Plugin=PS5Core, Path=OpenSplashFileSelectorCommand}">
                            <ButtonEx.Style>
                                <Style TargetType="ButtonEx">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ButtonEx">
                                                <Grid Width="889" Height="500">

                                                    <Image
                                                            Source="{PluginSettings Plugin=PS5Core, Path=SplashSelectorGameBg}"
                                                            Stretch="UniformToFill" />

                                                    <Image RenderOptions.BitmapScalingMode="Fant"
                                                            Source="{ThemeFile 'Assets/Backgrounds/Dashboard/PS5Overlay.png'}"
                                                            Stretch="UniformToFill" />

                                                    <Image Opacity="0.7"
                                                            Source="{ThemeFile 'Assets/Backgrounds/Dashboard/OverlayPicker2.png'}"
                                                            Stretch="UniformToFill" />

                                                    <Image x:Name="SplashPreviewImage" Stretch="UniformToFill" />

                                                    <Border x:Name="MainBorder" Margin="-6" BorderThickness="3"
                                                            CornerRadius="3" Opacity="1" Visibility="Hidden"
                                                            Style="{DynamicResource PS5Border}" Tag="False">
                                                        <Border.CacheMode>
                                                            <BitmapCache EnableClearType="False" RenderAtScale="1"
                                                                    SnapsToDevicePixels="False" />
                                                        </Border.CacheMode>
                                                    </Border>
                                                    <Border x:Name="FlashBorder" Margin="0" Opacity="1"
                                                            Visibility="Hidden" Style="{DynamicResource PS5Cover}"
                                                            Tag="False">
                                                        <Border.CacheMode>
                                                            <BitmapCache EnableClearType="False" RenderAtScale="1"
                                                                    SnapsToDevicePixels="False" />
                                                        </Border.CacheMode>
                                                    </Border>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter TargetName="MainBorder" Property="Visibility"
                                                                Value="Visible" />
                                                        <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                                                        <Setter TargetName="FlashBorder" Property="Visibility"
                                                                Value="Visible" />
                                                        <Setter TargetName="FlashBorder" Property="Tag" Value="True" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ButtonEx.Style>
                        </ButtonEx>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center"
                                VerticalAlignment="Top">
                            <ButtonEx Content="Cancel" Margin="20,0"
                                    Command="{PluginSettings Plugin=PS5Core, Path=CancelSplashscreenCommand}"
                                    Style="{DynamicResource PS5ButtonStyle}" />
                            <ButtonEx Content="Remove" Margin="20,0"
                                    Command="{PluginSettings Plugin=PS5Core, Path=RemoveSplashscreenCommand}">
                                <ButtonEx.Style>
                                    <Style TargetType="ButtonEx" BasedOn="{StaticResource PS5ButtonStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger
                                                    Binding="{PluginSettings Plugin=PS5Core, Path=HasCustomSplashscreen}"
                                                    Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ButtonEx.Style>
                            </ButtonEx>
                            <ButtonEx Content="Save" Margin="20,0"
                                    Command="{PluginSettings Plugin=PS5Core, Path=SaveSplashscreenCommand}"
                                    Style="{DynamicResource PS5ButtonStyle}" />
                        </StackPanel>

                        <Grid.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="0"
                                                Duration="0:0:0.20" FillBehavior="HoldEnd" />
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" BeginTime="0:0:0.20"
                                                From="0" To="1" Duration="0:0:0.35" FillBehavior="HoldEnd" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Grid.Triggers>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>