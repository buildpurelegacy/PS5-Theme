                                                    Margin="30,0,0,0" />
                                        </Grid>
                                    </StackPanel>

                                </ButtonEx>
                                <Border BorderThickness="0.5" BorderBrush="White" Margin="104,4,0,0"
                                        VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="525" Opacity="0.1" />

                                <ButtonEx Width="640" Height="90" Margin="0,6,0,0" Background="Transparent"
                                        HorizontalContentAlignment="Left"
                                        Command="{PluginSettings Plugin=PS5Core, Path=LogoutCommand}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Grid Width="48" HorizontalAlignment="Left">
                                            <Image Source="{ThemeFile 'Assets/Profile/Switch.png'}" Width="32"
                                                    VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        </Grid>
                                        <Grid Width="592" Height="90" VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="Switch Users" FontFamily="Segoe UI Light"
                                                    Foreground="White" VerticalAlignment="Center"
                                                    HorizontalAlignment="Left" FontSize="32" Margin="30,0,0,0" />
                                        </Grid>
                                    </StackPanel>

                                </ButtonEx>

                                <Border BorderThickness="0.5" BorderBrush="White" Margin="104,4,0,0"
                                        VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="525" Opacity="0.1" />

                                <ButtonEx Width="640" Height="90" Margin="0,6,0,0" Background="Transparent"
                                        HorizontalContentAlignment="Left"
                                        Command="{PluginSettings Plugin=PS5Core, Path=PowerExitCommand}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Grid Width="48" HorizontalAlignment="Left">
                                            <Image Source="{ThemeFile 'Assets/Profile/Exit.png'}" Width="32"
                                                    VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        </Grid>
                                        <Grid Width="592" Height="90" VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="Exit Playnite" FontFamily="Segoe UI Light"
                                                    Foreground="White" VerticalAlignment="Center"
                                                    HorizontalAlignment="Left" FontSize="32" Margin="30,0,0,0" />
                                        </Grid>
                                    </StackPanel>

                                </ButtonEx>

                            </StackPanel>

                        </Grid>

                        <MediaElement Source="{ThemeFile 'Assets/Power/PS5Power.mp4'}" UnloadedBehavior="Close">
                            <MediaElement.Style>
                                <Style TargetType="MediaElement">
                                    <Setter Property="MediaElementBehaviors.Repeat" Value="False" />
                                    <Setter Property="LoadedBehavior" Value="Close" />
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{PluginSettings Plugin=PS5Core, Path=IsPoweringOff}"
                                                Value="True">
                                            <Setter Property="LoadedBehavior" Value="Play" />
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </MediaElement.Style>
                        </MediaElement>
                    </Grid>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PS5OnlineStatus" TargetType="ContentControl">
