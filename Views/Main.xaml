                                                                                RenderOptions.BitmapScalingMode="Fant"
                                                                                Source="{ThemeFile 'Assets/Login/PS5Plus.png'}" />
                                                                    </StackPanel>

                                                                </StackPanel>
                                                                <ControlTemplate.Triggers>
