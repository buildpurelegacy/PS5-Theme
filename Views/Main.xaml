                                                VerticalAlignment="Center" FontFamily="Segoe UI Semibold" FontSize="18"
                                                Foreground="White" Text="Options" />

                                    </StackPanel>

                                    <StackPanel Orientation="Vertical" x:Name="PART_PS5CoreUsers" Margin="0,0,0,0"
                                            Width="5000" VerticalAlignment="Top">
