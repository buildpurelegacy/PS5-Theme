                                <Style TargetType="MediaElement">
                                    <Setter Property="MediaElementBehaviors.Repeat" Value="False" />
                                    <Setter Property="LoadedBehavior" Value="Close" />
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{PluginSettings Plugin=PS5Core, Path=IsPoweringOff}"
                                                Value="True">
                                            <Setter Property="LoadedBehavior" Value="Play" />
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </MediaElement.Style>
                        </MediaElement>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PS5ProfileMenu" TargetType="ContentControl">
