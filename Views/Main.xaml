<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:pbeh="clr-namespace:Playnite.Behaviors;assembly=Playnite"
        xmlns:pin="clr-namespace:Playnite.Input;assembly=Playnite" mc:Ignorable="d">

    <Style TargetType="{x:Type Main}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Main}">
                    <Grid x:Name="PART_MainHost" Background="Black" d:DesignWidth="{StaticResource DesignWidth}"
                            d:DesignHeight="{StaticResource DesignHeight}"
                            d:DataContext="{x:Static DesignMainViewModel.DesignIntance}">
                        <Grid x:Name="PART_ViewHostAlt" Background="Black">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{PluginSettings Plugin=PS5Core, Path=WizardCompleted}"
                                                Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger
                                                Binding="{PluginStatus Plugin=PS5Core_84d85c00-14b1-4859-805f-6bd9d95fdae9, Status=Installed}"
                                                Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ElementName=LoginPage, Path=Visibility}"
                                                Value="Visible">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <FadeImage x:Name="PART_ImageBackground" HorizontalAlignment="Center"
                                    VerticalAlignment="Top" />

                            <Image HorizontalAlignment="Left" VerticalAlignment="Top"
                                    RenderOptions.BitmapScalingMode="Fant"
                                    Source="{ThemeFile 'Assets/Backgrounds/Dashboard/PS5Overlay.png'}" Stretch="Fill" />

                            <Grid x:Name="PART_TopGrid" Height="100" VerticalAlignment="Top" HorizontalAlignment="Right"
                                    Width="1920">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Style.Triggers>
                                            <DataTrigger
                                                    Binding="{PluginSettings Plugin=PS5Core, Path=IsMainContentFocused}"
                                                    Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                    From="1" To="0" Duration="0:0:0.2" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                    From="0" To="1" Duration="0:0:0.2" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                            <Trigger Property="Opacity" Value="0">
                                                <Setter Property="Focusable" Value="False" />
                                            </Trigger>
                                            <DataTrigger Binding="{PluginSettings Plugin=PS5Core, Path=IsEditMode}"
                                                    Value="True">
                                                <Setter Property="Focusable" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>

                                <StackPanel x:Name="MainButtons" Margin="40,35,0,0" HorizontalAlignment="Left"
                                        VerticalAlignment="Top" Orientation="Horizontal">

                                    <TextBlock FontFamily="{StaticResource FontPlayStation4Controller}" Opacity="0.7"
                                            Foreground="White" Text="f" FontSize="35" VerticalAlignment="Center" />

                                    <ButtonEx x:Name="PART_PSPlusButton"
                                            Command="{PluginSettings Plugin=PS5Core, Path=ActivatePSPlusCommand}">
                                        <ButtonEx.Template>
                                            <ControlTemplate TargetType="ButtonEx">
                                                <Grid Height="60" Width="60" Margin="35,0,0,0">
                                                    <Border x:Name="MainBorder" BorderThickness="3" CornerRadius="25"
                                                            Style="{DynamicResource PS5Border}" Visibility="Hidden" />
                                                    <Image Width="35" Height="35" VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            Source="{ThemeFile 'Assets/Buttons/Dashboard/PS5Plus.png'}" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter TargetName="MainBorder" Property="Visibility"
                                                                Value="Visible" />
                                                        <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                                                    </Trigger>
                                                    <DataTrigger
                                                            Binding="{PluginSettings Plugin=PS5Core, Path=IsEditMode}"
                                                            Value="True">
                                                        <Setter Property="Focusable" Value="False" />
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ButtonEx.Template>
                                    </ButtonEx>

                                    <ButtonEx x:Name="PART_PSStoreButton"
                                            Command="{PluginSettings Plugin=PS5Core, Path=ActivatePSStoreCommand}">
                                        <ButtonEx.Template>
                                            <ControlTemplate TargetType="ButtonEx">
                                                <Grid Height="60" Width="60" Margin="65,0,0,0">
                                                    <Border x:Name="MainBorder" BorderThickness="3" CornerRadius="25"
                                                            Style="{DynamicResource PS5Border}" Visibility="Hidden" />
                                                    <Image Width="35" Height="35" VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            Source="{ThemeFile 'Assets/Buttons/Dashboard/PS5Store.png'}" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter TargetName="MainBorder" Property="Visibility"
                                                                Value="Visible" />
                                                        <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                                                    </Trigger>
                                                    <DataTrigger
                                                            Binding="{PluginSettings Plugin=PS5Core, Path=IsEditMode}"
                                                            Value="True">
                                                        <Setter Property="Focusable" Value="False" />
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ButtonEx.Template>
                                    </ButtonEx>

                                    <ButtonEx x:Name="PART_PSGamesButton"
                                            Command="{PluginSettings Plugin=PS5Core, Path=ActivatePSGamesCommand}">
                                        <ButtonEx.Template>
                                            <ControlTemplate TargetType="ButtonEx">
                                                <Grid Height="60" Width="60" Margin="65,0,0,0">
                                                    <Border x:Name="MainBorder" BorderThickness="3" CornerRadius="25"
                                                            Style="{DynamicResource PS5Border}" Visibility="Hidden" />
                                                    <Image Width="35" Height="35" VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            Source="{ThemeFile 'Assets/Buttons/Dashboard/PS5Games.png'}" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter TargetName="MainBorder" Property="Visibility"
                                                                Value="Visible" />
                                                        <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                                                    </Trigger>
                                                    <DataTrigger
                                                            Binding="{PluginSettings Plugin=PS5Core, Path=IsEditMode}"
                                                            Value="True">
                                                        <Setter Property="Focusable" Value="False" />
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ButtonEx.Template>
                                    </ButtonEx>

                                    <ButtonEx x:Name="PART_PSLibraryButton"
                                            Command="{PluginSettings Plugin=PS5Core, Path=ActivatePSLibraryCommand}">
                                        <ButtonEx.Template>
                                            <ControlTemplate TargetType="ButtonEx">
                                                <Grid Height="60" Width="60" Margin="65,0,0,0">
                                                    <Border x:Name="MainBorder" BorderThickness="3" CornerRadius="25"
                                                            Style="{DynamicResource PS5Border}" Visibility="Hidden" />
                                                    <Image Width="35" Height="35" VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            Source="{ThemeFile 'Assets/Buttons/Dashboard/PS5MoreGames.png'}" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter TargetName="MainBorder" Property="Visibility"
                                                                Value="Visible" />
                                                        <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                                                    </Trigger>
                                                    <DataTrigger
                                                            Binding="{PluginSettings Plugin=PS5Core, Path=IsEditMode}"
                                                            Value="True">
                                                        <Setter Property="Focusable" Value="False" />
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ButtonEx.Template>
                                    </ButtonEx>

                                    <ButtonEx x:Name="PART_PSMediaButton"
                                            Command="{PluginSettings Plugin=PS5Core, Path=ActivatePSMediaCommand}">
                                        <ButtonEx.Template>
                                            <ControlTemplate TargetType="ButtonEx">
                                                <Grid Height="60" Width="60" Margin="65,0,0,0">
                                                    <Border x:Name="MainBorder" BorderThickness="3" CornerRadius="25"
                                                            Style="{DynamicResource PS5Border}" Visibility="Hidden" />
                                                    <Image Width="35" Height="35" VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            Source="{ThemeFile 'Assets/Buttons/Dashboard/PS5MoreMedia.png'}" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter TargetName="MainBorder" Property="Visibility"
                                                                Value="Visible" />
                                                        <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                                                    </Trigger>
                                                    <DataTrigger
                                                            Binding="{PluginSettings Plugin=PS5Core, Path=IsEditMode}"
                                                            Value="True">
                                                        <Setter Property="Focusable" Value="False" />
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ButtonEx.Template>
                                    </ButtonEx>
                                    <TextBlock FontFamily="{StaticResource FontPlayStation4Controller}" Opacity="0.7"
                                            Margin="35,0,0,0" Foreground="White" Text="l" FontSize="35"
                                            VerticalAlignment="Center" />

                                </StackPanel>

                                <Grid x:Name="Clock" Margin="0,35,0,0" Width="270" HorizontalAlignment="Right"
                                        VerticalAlignment="Top">
                                    <TextBlock x:Name="PART_TextClock" Margin="50,0,0,0" HorizontalAlignment="Left"
                                            VerticalAlignment="Center" FontFamily="Segoe UI SemiLight" FontSize="38"
                                            Style="{DynamicResource TextBlockBaseStyle}" />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,35,270,0" VerticalAlignment="Top"
                                        HorizontalAlignment="Right">
                                    <ButtonEx x:Name="PART_ButtonSearchCustom" Margin="0,0,50,0" Width="48" Height="48"
                                            HorizontalAlignment="Left" VerticalAlignment="Center"
                                            Command="{PluginSettings Plugin=PS5Core, Path=CustomSearchCommand}">
                                        <ButtonEx.Style>
                                            <Style TargetType="ButtonEx">
                                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Grid Width="48" Height="48">
                                                                <Border x:Name="mask" Background="Transparent"
                                                                        CornerRadius="48" />
                                                                <Grid>
                                                                    <Grid.OpacityMask>
                                                                        <VisualBrush Visual="{Binding ElementName=mask}" />
                                                                    </Grid.OpacityMask>
                                                                </Grid>
                                                                <TextBlock x:Name="Text" Margin="0,0,0,0"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        FontFamily="{DynamicResource FontIcoFont}"
                                                                        FontSize="30" Foreground="White" Text="&#xec82;" />
                                                                <Border x:Name="MainBorder" Margin="-6"
                                                                        BorderThickness="3" CornerRadius="48"
                                                                        Opacity="1" Style="{DynamicResource PS5Border}"
                                                                        Tag="False" Visibility="Hidden">
                                                                    <Border.CacheMode>
                                                                        <BitmapCache EnableClearType="False"
                                                                                RenderAtScale="1"
                                                                                SnapsToDevicePixels="False" />
                                                                    </Border.CacheMode>
                                                                </Border>
                                                            </Grid>

                                                            <ControlTemplate.Triggers>
                                                                <DataTrigger
                                                                        Binding="{PluginSettings Plugin=PS5Core, Path=IsMainContentFocused}"
                                                                        Value="True">
                                                                    <Setter Property="Focusable" Value="False" />
                                                                </DataTrigger>
                                                                <DataTrigger
                                                                        Binding="{Binding ElementName=PSLIBRARY_Content, Path=IsKeyboardFocusWithin}"
                                                                        Value="True">
                                                                    <Setter Property="Focusable" Value="False" />
                                                                </DataTrigger>
                                                                <Trigger Property="IsFocused" Value="True">
                                                                    <Setter TargetName="MainBorder"
                                                                            Property="Visibility" Value="Visible" />
                                                                    <Setter TargetName="MainBorder" Property="Tag"
                                                                            Value="True" />
                                                                    <Setter TargetName="mask" Property="Background"
                                                                            Value="#eeeeee" />
                                                                    <Setter TargetName="Text" Property="Foreground"
                                                                            Value="#2e2e2e" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ButtonEx.Style>
                                    </ButtonEx>

                                    <ButtonEx x:Name="PART_ButtonMainMenu" Margin="0,0,50,0" Width="48" Height="48"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <ButtonEx.Style>
                                            <Style TargetType="ButtonEx">
                                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Grid Width="48" Height="48">
                                                                <Border x:Name="mask" Background="Transparent"
                                                                        CornerRadius="48" />
                                                                <Grid>
                                                                    <Grid.OpacityMask>
                                                                        <VisualBrush Visual="{Binding ElementName=mask}" />
                                                                    </Grid.OpacityMask>
                                                                </Grid>
                                                                <TextBlock x:Name="Text" Margin="0,0,0,0"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        FontFamily="{DynamicResource FontIcoFont}"
                                                                        FontSize="36" Foreground="White" Text="&#xefb0;" />
                                                                <Border x:Name="MainBorder" Margin="-6"
                                                                        BorderThickness="3" CornerRadius="48"
                                                                        Opacity="1" Style="{DynamicResource PS5Border}"
                                                                        Tag="False" Visibility="Hidden">
                                                                    <Border.CacheMode>
                                                                        <BitmapCache EnableClearType="False"
                                                                                RenderAtScale="1"
                                                                                SnapsToDevicePixels="False" />
                                                                    </Border.CacheMode>
                                                                </Border>
                                                            </Grid>

                                                            <ControlTemplate.Triggers>
                                                                <DataTrigger
                                                                        Binding="{PluginSettings Plugin=PS5Core, Path=IsMainContentFocused}"
                                                                        Value="True">
                                                                    <Setter Property="Focusable" Value="False" />
                                                                </DataTrigger>
                                                                <DataTrigger
                                                                        Binding="{Binding ElementName=PSLIBRARY_Content, Path=IsKeyboardFocusWithin}"
                                                                        Value="True">
                                                                    <Setter Property="Focusable" Value="False" />
                                                                </DataTrigger>
                                                                <Trigger Property="IsFocused" Value="True">
                                                                    <Setter TargetName="MainBorder"
                                                                            Property="Visibility" Value="Visible" />
                                                                    <Setter TargetName="MainBorder" Property="Tag"
                                                                            Value="True" />
                                                                    <Setter TargetName="mask" Property="Background"
                                                                            Value="#eeeeee" />
                                                                    <Setter TargetName="Text" Property="Foreground"
                                                                            Value="#2e2e2e" />
                                                                </Trigger>

                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ButtonEx.Style>
                                    </ButtonEx>

                                    <ButtonEx x:Name="PART_ButtonProfile" Margin="0,0,50,0"
                                            Command="{PluginSettings Plugin=PS5Core, Path=OpenProfileMenuCommand}"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ButtonEx">
                                                            <Grid Width="48" Height="48">
                                                                <Border Name="mask" Background="Black" CornerRadius="48" />
                                                                <Grid>
                                                                    <Grid.OpacityMask>
                                                                        <VisualBrush Visual="{Binding ElementName=mask}" />
                                                                    </Grid.OpacityMask>
                                                                    <Image HorizontalAlignment="Left"
                                                                            VerticalAlignment="Top"
                                                                            RenderOptions.BitmapScalingMode="Fant"
                                                                            Source="{PluginSettings Plugin=PS5Core, Path=SelectedUserItem.AvatarPath}"
                                                                            Stretch="Uniform" />

                                                                </Grid>
                                                                <Border x:Name="MainBorder" Margin="-6"
                                                                        BorderThickness="3" CornerRadius="48"
                                                                        Opacity="1" Style="{DynamicResource PS5Border}"
                                                                        Tag="False" Visibility="Hidden">
                                                                    <Border.CacheMode>
                                                                        <BitmapCache EnableClearType="False"
                                                                                RenderAtScale="1"
                                                                                SnapsToDevicePixels="False" />
                                                                    </Border.CacheMode>
                                                                </Border>
                                                                <Canvas Margin="26,24,0,0" HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center">
                                                                    <Ellipse x:Name="NotifLight" Width="12" Height="12">
                                                                        <Ellipse.Style>
                                                                            <Style TargetType="Ellipse">
                                                                                <Setter Property="Fill" Value="#14fe83" />

                                                                                <Style.Triggers>
                                                                                    <DataTrigger
                                                                                            Binding="{PluginSettings Plugin=PS5Core, Path=SelfState}"
                                                                                            Value="online">
                                                                                        <Setter Property="Fill"
                                                                                                Value="#14fe83" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger
                                                                                            Binding="{PluginSettings Plugin=PS5Core, Path=SelfState}"
                                                                                            Value="away">
                                                                                        <Setter Property="Fill"
                                                                                                Value="#fca612" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger
                                                                                            Binding="{PluginSettings Plugin=PS5Core, Path=SelfState}"
                                                                                            Value="offline">
                                                                                        <Setter Property="Fill"
                                                                                                Value="Transparent" />
                                                                                        <Setter Property="Stroke"
                                                                                                Value="White" />
                                                                                        <Setter
                                                                                                Property="StrokeDashArray"
                                                                                                Value="2 2" />
                                                                                    </DataTrigger>

                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Ellipse.Style>
                                                                    </Ellipse>
                                                                </Canvas>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsFocused" Value="True">
                                                                    <Setter TargetName="MainBorder"
                                                                            Property="Visibility" Value="Visible" />
                                                                    <Setter TargetName="MainBorder" Property="Tag"
                                                                            Value="True" />
                                                                </Trigger>
                                                                <DataTrigger
                                                                        Binding="{PluginSettings Plugin=PS5Core, Path=IsMainContentFocused}"
                                                                        Value="True">
                                                                    <Setter Property="Focusable" Value="False" />
                                                                </DataTrigger>
                                                                <DataTrigger
                                                                        Binding="{Binding ElementName=PSLIBRARY_Content, Path=IsKeyboardFocusWithin}"
                                                                        Value="True">
                                                                    <Setter Property="Focusable" Value="False" />
                                                                </DataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </ButtonEx>

                                </StackPanel>
                            </Grid>

                            <Grid x:Name="MainDashboardPanel" VerticalAlignment="Top" HorizontalAlignment="Left">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Opacity" Value="0" />

                                        <Style.Triggers>
                                            <DataTrigger Binding="{PluginSettings Plugin=PS5Core, Path=ActiveSection}"
                                                    Value="PSGAMES">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                    From="0" To="0" Duration="0:0:0.5" />
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                    From="0" To="1" BeginTime="0:0:0.5"
                                                                    Duration="0:0:0.2" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                    From="1" To="0" Duration="0:0:0.2" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                            <Trigger Property="Opacity" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <TextBlock x:Name="IDChange" Visibility="Collapsed"
                                        Text="{PluginSettings Plugin=PS5Core, Path=SelectedHomeItem.Id}" />

                                <StackPanel x:Name="PS5Title" Orientation="Horizontal"
                                        Tag="{Binding ElementName=IDChange, Path=Text, NotifyOnTargetUpdated=True}">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Margin" Value="357,241,0,0" />
                                            <Style.Triggers>
                                                <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                    From="0" To="1" Duration="0:0:0.2" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <DataTrigger Binding="{PluginSettings Plugin=PS5Core, Path=IsEditMode}"
                                                        Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger
                                                        Binding="{PluginSettings Plugin=PS5Core, Path=IsMainContentFocused}"
                                                        Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                                        From="357,241,0,0" To="172,64,0,0"
                                                                        Duration="0:0:0.2" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                                        To="357,241,0,0" From="172,64,0,0"
                                                                        Duration="0:0:0.2" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Image x:Name="PlatformSource" Height="33" Margin="0,5,7,0"
                                            HorizontalAlignment="Left" VerticalAlignment="Top"
                                            RenderOptions.BitmapScalingMode="Fant"
                                            Source="{Binding SelectedGame.Platforms[0].Icon, Converter={StaticResource ImageStringToImageConverter}}">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Style.Triggers>
                                                    <DataTrigger
                                                            Binding="{PluginSettings Plugin=PS5Core, Path=SelectedHomeItem.Id}"
                                                            Value="PSWELCOME">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger
                                                            Binding="{PluginSettings Plugin=PS5Core, Path=SelectedHomeItem.Id}"
                                                            Value="PSSTORE">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger
                                                            Binding="{PluginSettings Plugin=PS5Core, Path=SelectedHomeItem.Id}"
                                                            Value="PSPLUS">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger
                                                            Binding="{PluginSettings Plugin=PS5Core, Path=SelectedHomeItem.Id}"
                                                            Value="PSLIBRARY">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                    <TextBlock Margin="0,0,0,0" FontFamily="Segoe UI Light" FontSize="31"
                                            Foreground="White">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding SelectedGame.DisplayName}" />
                                                <Style.Triggers>
                                                    <DataTrigger
                                                            Binding="{PluginSettings Plugin=PS5Core, Path=SelectedHomeItem.Id}"
                                                            Value="PSWELCOME">
                                                        <Setter Property="Text" Value="Welcome" />
                                                    </DataTrigger>
                                                    <DataTrigger
                                                            Binding="{PluginSettings Plugin=PS5Core, Path=SelectedHomeItem.Id}"
                                                            Value="PSSTORE">
                                                        <Setter Property="Text" Value="PlayStation Store" />
                                                    </DataTrigger>
                                                    <DataTrigger
                                                            Binding="{PluginSettings Plugin=PS5Core, Path=SelectedHomeItem.Id}"
                                                            Value="PSPLUS">
                                                        <Setter Property="Text" Value="PlayStation Plus" />
                                                    </DataTrigger>
                                                    <DataTrigger
                                                            Binding="{PluginSettings Plugin=PS5Core, Path=SelectedHomeItem.Id}"
                                                            Value="PSLIBRARY">
                                                        <Setter Property="Text" Value="Game Library" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Image Height="24" Margin="15,13,10,0" VerticalAlignment="Top" Opacity="0.9"
                                            RenderOptions.BitmapScalingMode="Fant" Source="{ThemeFileBinding SelectedGame.Source.Name,
    PathFormat='Assets/Source/{0}.png'}">
                                        <Image.Style>
