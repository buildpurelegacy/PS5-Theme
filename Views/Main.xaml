                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Grid Width="35" HorizontalAlignment="Left">
                                        <TextBlock Margin="-5,0,5,0" HorizontalAlignment="Center"
                                                VerticalAlignment="Center" Text="&#xeed6;"
                                                FontFamily="{StaticResource FontIcoFont}" Foreground="White"
                                                FontSize="34">
