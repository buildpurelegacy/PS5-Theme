                            <Setter TargetName="BackgroundBorder" Property="Background" Value="#eeeeee" />
                            <Setter TargetName="MainBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                        </Trigger>
                        <DataTrigger Binding="{Binding SelectedGame.IsRunning}" Value="True">
                            <Setter TargetName="Content" Property="Content" Value="{DynamicResource LOCGameRunning}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                            <Setter TargetName="Content" Property="Content" Value="{DynamicResource LOCGameRunning}" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
