    <Style x:Key="PS5NowPlayingButton" BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
        <Setter Property="Margin" Value="0,0,0,0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="Visibility" Value="Collapsed" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Margin="0,0,0,0" VerticalAlignment="Top" Background="Transparent">
                        <Border x:Name="BackgroundBorder" Height="72" MinWidth="375" Margin="0"
                                Background="{TemplateBinding Background}" BorderBrush="#5A5A5A" BorderThickness="0"
                                CornerRadius="35" />
                        <StackPanel Margin="100,-2,100,2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Orientation="Horizontal">
                            <TextBlock x:Name="Text1" Margin="0,0,0,0" HorizontalAlignment="Left"
                                    VerticalAlignment="Center" FontFamily="Segoe UI Semibold" FontSize="30"
                                    Foreground="White" Text="{DynamicResource LOCNowPlayingBack}" />
                        </StackPanel>

                        <Border x:Name="MainBorder" Margin="-6" BorderThickness="3" CornerRadius="36" Opacity="1"
                                Style="{DynamicResource PS5Border}" Tag="False" Visibility="Hidden">
                            <Border.CacheMode>
                                <BitmapCache EnableClearType="False" RenderAtScale="1" SnapsToDevicePixels="False" />
                            </Border.CacheMode>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            <Setter TargetName="BackgroundBorder" Property="Background" Value="#40808080" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Text1" Property="Foreground" Value="#2e2e2e" />
                            <Setter TargetName="BackgroundBorder" Property="Background" Value="#eeeeee" />
                            <Setter TargetName="MainBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Text1" Property="Foreground" Value="#2e2e2e" />
                            <Setter TargetName="BackgroundBorder" Property="Background" Value="#eeeeee" />
                            <Setter TargetName="MainBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                        </Trigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition
                                        Binding="{PluginStatus Plugin=NowPlaying_db4e7ade-57fb-426c-8392-60e2347a0209, Status=Installed}"
                                        Value="True" />
                                <Condition Binding="{Binding SelectedGame.IsRunning}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <MultiDataTrigger.Setters>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger.Setters>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition
                                        Binding="{PluginStatus Plugin=NowPlaying_db4e7ade-57fb-426c-8392-60e2347a0209, Status=Installed}"
                                        Value="True" />
                                <Condition Binding="{Binding IsRunning}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <MultiDataTrigger.Setters>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger.Setters>
                        </MultiDataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

