<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Style TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Padding" Value="12,5,12,5" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Background="{TemplateBinding Background}">
                        <TextBlock Margin="20,10,20,10" FontFamily="Segoe UI SemiLight" FontSize="30"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Grid.Column="1"
                                TextTrimming="WordEllipsis">
                        <ContentPresenter RecognizesAccessKey="True" />
                        </TextBlock>

                        <Border x:Name="MainBorder" Margin="-6" BorderThickness="3" CornerRadius="3" Opacity="1"
                                Style="{DynamicResource PS5Border}" Tag="False" Visibility="Hidden">
                            <Border.CacheMode>
                                <BitmapCache EnableClearType="False" RenderAtScale="1" SnapsToDevicePixels="False" />
                            </Border.CacheMode>
                        </Border>
                        <Border x:Name="FlashBorder" Margin="0" Opacity="1" Style="{DynamicResource PS5Cover}"
                                Tag="False" Visibility="Hidden">
                            <Border.CacheMode>
                                <BitmapCache EnableClearType="False" RenderAtScale="1" SnapsToDevicePixels="False" />
                            </Border.CacheMode>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="MainBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                            <Setter TargetName="FlashBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="FlashBorder" Property="Tag" Value="True" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                            <Setter TargetName="FlashBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="FlashBorder" Property="Tag" Value="True" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource TextBrushDark}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ButtonEx" BasedOn="{StaticResource {x:Type Button}}">
    </Style>

    <Style x:Key="PS5ButtonStyle" BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
        <Setter Property="Margin" Value="0,0,0,0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Margin="0,0,0,0" VerticalAlignment="Top" Background="Transparent">
                        <Border x:Name="BackgroundBorder" Height="72" MinWidth="375" Margin="0"
                                Background="{TemplateBinding Background}" BorderBrush="#5A5A5A" BorderThickness="0"
                                CornerRadius="35" />
                        <StackPanel Margin="50,-2,50,2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Orientation="Horizontal">
                            <TextBlock x:Name="Text1" Margin="0,0,0,0" HorizontalAlignment="Left"
                                    VerticalAlignment="Center" FontFamily="Segoe UI Semibold" FontSize="30"
                                    Foreground="White">
                                <ContentPresenter x:Name="Content" />
                            </TextBlock>
                        </StackPanel>

                        <Border x:Name="MainBorder" Margin="-6" BorderThickness="3" CornerRadius="36" Opacity="1"
                                Style="{DynamicResource PS5Border}" Tag="False" Visibility="Hidden">
                            <Border.CacheMode>
                                <BitmapCache EnableClearType="False" RenderAtScale="1" SnapsToDevicePixels="False" />
                            </Border.CacheMode>
                        </Border>

                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            <Setter TargetName="BackgroundBorder" Property="Background" Value="#40808080" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Text1" Property="Foreground" Value="#2e2e2e" />
                            <Setter TargetName="BackgroundBorder" Property="Background" Value="#eeeeee" />
                            <Setter TargetName="MainBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                            
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Text1" Property="Foreground" Value="#2e2e2e" />
                            <Setter TargetName="BackgroundBorder" Property="Background" Value="#eeeeee" />
                            <Setter TargetName="MainBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PS5TurnExit" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Padding" Value="12,5,12,5" />
        <Setter Property="Tag" Value="{DynamicResource HidePower2}" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="BorderBrush" Value="{DynamicResource SelectionLightBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid x:Name="Main">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="WhiteIcon" Grid.Column="0" Margin="0,5,0,0" HorizontalAlignment="Center"
                                    VerticalAlignment="Top" FontFamily="{DynamicResource FontIcoFont}" FontSize="42"
                                    Foreground="#d8dbe0" Text="&#xeee4;" />
                            <StackPanel Grid.Column="1" Margin="10,5,0,0" Orientation="Vertical">
                                <TextBlock Margin="0,5,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
                                        FontFamily="Segoe UI Light" FontSize="28" Foreground="White">
                                    <ContentPresenter />
                                </TextBlock>

                                <TextBlock x:Name="Description" Width="540" Margin="0,10,0,10"
                                        HorizontalAlignment="Left" VerticalAlignment="Top" FontFamily="Segoe UI Light"
                                        FontSize="24" Foreground="White" Opacity="0.7"
                                        Text="Close Playnite application." TextWrapping="Wrap" Visibility="Collapsed" />
                            </StackPanel>

                        </Grid>

                        <Border x:Name="MainBorder" Margin="-6" BorderThickness="3" CornerRadius="3" Opacity="1"
                                Style="{DynamicResource PS5Border}" Tag="False" Visibility="Hidden">
                            <Border.CacheMode>
                                <BitmapCache EnableClearType="False" RenderAtScale="1" SnapsToDevicePixels="False" />
                            </Border.CacheMode>
                        </Border>
                        <Border x:Name="FlashBorder" Margin="0" CornerRadius="0" Opacity="1"
                                Style="{DynamicResource PS5Cover}" Tag="False" Visibility="Hidden">
                            <Border.CacheMode>
                                <BitmapCache EnableClearType="False" RenderAtScale="1" SnapsToDevicePixels="False" />
                            </Border.CacheMode>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="MainBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                            <Setter TargetName="FlashBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="FlashBorder" Property="Tag" Value="True" />
                            <Setter TargetName="Description" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="MainBorder" Property="Tag" Value="True" />
                            <Setter TargetName="FlashBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="FlashBorder" Property="Tag" Value="True" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource TextBrushDark}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


